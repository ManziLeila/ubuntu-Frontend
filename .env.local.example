# Optional: fixed API base. If unset, the browser uses the same hostname as this app + NEXT_PUBLIC_API_PORT (default 3001)
# — works for http://localhost:3000, http://YOUR_PUBLIC_IP:3000, etc.
# NEXT_PUBLIC_API_URL=http://localhost:3001
# NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
NEXT_PUBLIC_API_PORT=3001

# Or point at a bare core dev server (e.g. PORT=4001):
# NEXT_PUBLIC_API_URL=http://localhost:4001
# NEXT_PUBLIC_SOCKET_URL=http://localhost:4001

# Google OAuth - must match GOOGLE_CLIENT_ID in the backend .env
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
